OPENAI_API_KEY=
OPENAI_MODELS=

GEMINI_API_KEY=
GEMINI_MODELS=

GROQ_API_KEY=
GROQ_MODELS=

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODELS=

# Search APIs (optional — improves candidate generation)
